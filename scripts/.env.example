# Copy this file to scripts/.env and fill in your App Store Connect API key details.
# scripts/.env is git-ignored. release.sh sources it automatically.
#
# Create the key at: App Store Connect → Users and Access → Integrations
#   → App Store Connect API → generate a key with "App Manager" access.
# Download the .p8 ONCE (Apple won't let you re-download it) and store it at the path below.

export ASC_KEY_ID="XXXXXXXXXX"
export ASC_ISSUER_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
export ASC_KEY_PATH="$HOME/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8"
